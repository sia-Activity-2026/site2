APP_NAME=DDS-Backend-2
APP_ENV=production
APP_DEBUG=false
APP_URL=https://ddsbe2.railway.app
APP_KEY=base64:YOUR_KEY_HERE
APP_TIMEZONE=UTC

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=${DB_HOST}
DB_PORT=3306
DB_DATABASE=${BE2_DB_NAME}
DB_USERNAME=${DB_USERNAME}
DB_PASSWORD=${DB_PASSWORD}

CACHE_DRIVER=array
QUEUE_CONNECTION=sync

ACCEPTED_SECRETS=${USERS2_SERVICE_SECRET}
